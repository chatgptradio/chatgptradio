# ChatGPT Radio — Environment Variables
# Copy this file to .env and fill in your values.

# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key — used for journal narration and track naming
OPENAI_API_KEY=

# Fal.ai API key — used for Stable Audio 2.5 music generation
FAL_API_KEY=

# YouTube Data API v3 key — used for live chat collection
YOUTUBE_API_KEY=

# YouTube stream key — used to push RTMP to your channel
YOUTUBE_STREAM_KEY=

# Your YouTube channel ID (UCxxxxxxxxxxxxxxxx)
YOUTUBE_CHANNEL_ID=

# Your YouTube live video ID (leave empty to auto-detect from channel)
YOUTUBE_VIDEO_ID=

# ── Optional collectors ───────────────────────────────────────────────────────

# Reddit API credentials (for reddit collector)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ChatGPTRadio/1.0

# NewsAPI key (https://newsapi.ai)
NEWSAPI_AI_KEY=

# MediaCloud API key (https://mediacloud.org)
MEDIA_CLOUD_API_KEY=

# ── Streaming / overlay ───────────────────────────────────────────────────────

# Custom RTMP URL (overrides YOUTUBE_RTMP_URL + YOUTUBE_STREAM_KEY if set)
RTMP_URL=

# YouTube RTMP ingest base URL (default: rtmp://a.rtmp.youtube.com/live2)
YOUTUBE_RTMP_URL=

# X11 display for Chromium overlay (default: :99)
OVERLAY_DISPLAY=:99

# HTTP port for overlay server (default: 8080)
OVERLAY_HTTP_PORT=8080

# Set to 0 to disable the browser overlay (default: 1)
USE_OVERLAY=1
